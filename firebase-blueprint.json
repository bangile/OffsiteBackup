{
  "entities": {
    "DriveRecord": {
      "title": "Drive Record",
      "description": "Monthly record of offsite backup hard drive rotation",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["offsite", "onsite", "pending"]
        },
        "month": {
          "type": "string",
          "description": "Display name of the month (e.g. April 2026)"
        },
        "checkIn": {
          "$ref": "#/entities/ActionLog"
        },
        "checkOut": {
          "$ref": "#/entities/ActionLog"
        }
      },
      "required": ["status", "month"]
    },
    "ActionLog": {
      "title": "Action Log",
      "description": "Snapshot of a check-in or check-out event",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "transporterName": { "type": "string" },
        "signature": { "type": "string", "description": "Base64 signature image" }
      },
      "required": ["timestamp", "transporterName", "signature"]
    },
    "Issue": {
      "title": "Issue",
      "description": "A logged hardware or process concern",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "reporter": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "required": ["timestamp", "reporter", "message", "severity"]
    }
  },
  "firestore": {
    "driveRecords/{monthId}": {
      "schema": "DriveRecord",
      "description": "Top-level container for each month's drive rotation data"
    },
    "driveRecords/{monthId}/issues/{issueId}": {
      "schema": "Issue",
      "description": "List of issues logged for a specific rotation month"
    }
  }
}
